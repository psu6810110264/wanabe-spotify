<PlayerScreen>:
    name: "player"
    md_bg_color: .07, .04, .14, 1

    MDBoxLayout:
        orientation: "vertical"
        padding: [dp(18), dp(18), dp(18), dp(18)]
        spacing: dp(16)

        MDBoxLayout:
            adaptive_height: True

            MDIconButton:
                icon: "arrow-left"
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1
                on_release: root.back_home()

            Widget:

            MDIconButton:
                icon: "heart" if root.is_favorite_song else "heart-outline"
                theme_text_color: "Custom"
                text_color: (1, .35, .65, 1) if root.is_favorite_song else (.95, .68, .82, 1)
                on_release: root.toggle_favorite_song()

            MDIconButton:
                icon: "dots-horizontal"
                theme_text_color: "Custom"
                text_color: .9, .9, .95, 1

        MDCard:
            size_hint_y: None
            height: dp(300)
            radius: [32,]
            elevation: 0
            md_bg_color: .20, .13, .34, 1
            padding: dp(24)

            MDBoxLayout:
                orientation: "vertical"
                spacing: dp(14)

                Widget:

                MDLabel:
                    text: "◉"
                    halign: "center"
                    valign: "middle"
                    theme_text_color: "Custom"
                    text_color: 1, .63, .85, 1
                    font_style: "H1"

                MDLabel:
                    text: "grape music"
                    halign: "center"
                    font_style: "Button"
                    theme_text_color: "Custom"
                    text_color: .86, .86, .95, 1

                Widget:

        MDBoxLayout:
            orientation: "vertical"
            size_hint_y: None
            height: dp(56)
            spacing: dp(4)

            MDLabel:
                text: root.song_title
                font_style: "H6"
                bold: True
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1
                size_hint_y: None
                height: dp(30)
                shorten: True

            MDLabel:
                text: root.song_artist
                font_style: "Subtitle2"
                theme_text_color: "Custom"
                text_color: .77, .77, .84, 1
                size_hint_y: None
                height: dp(22)
                shorten: True

        MDSlider:
            min: 0
            max: 100
            value: root.progress
            hint: False
            on_value: root.on_seek(self.value)

        MDBoxLayout:
            adaptive_height: True

            MDLabel:
                text: root.current_time
                font_style: "Caption"
                theme_text_color: "Custom"
                text_color: .72, .72, .80, 1

            MDLabel:
                text: root.song_duration
                font_style: "Caption"
                halign: "right"
                theme_text_color: "Custom"
                text_color: .72, .72, .80, 1

        Widget:

        MDBoxLayout:
            adaptive_height: True
            spacing: dp(16)
            padding: [dp(6), 0, dp(6), 0]

            MDIconButton:
                icon: "skip-previous"
                user_font_size: "42sp"
                theme_text_color: "Custom"
                text_color: .93, .93, 1, 1
                on_release: root.on_prev()

            MDRoundFlatIconButton:
                text: "Pause" if root.is_playing else "Play"
                icon: "pause" if root.is_playing else "play"
                md_bg_color: 1, .63, .85, 1
                text_color: .12, .08, .18, 1
                line_color: 1, .63, .85, 1
                on_release: root.toggle_play_pause()

            MDIconButton:
                icon: "skip-next"
                user_font_size: "42sp"
                theme_text_color: "Custom"
                text_color: .93, .93, 1, 1
                on_release: root.on_next()


