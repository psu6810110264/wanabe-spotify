#:kivy 2.3.0

RootWidget:
    current: "login"
    LoginScreen:
    HomeScreen:
    PlayerScreen:
    SearchScreen:
    FavoriteScreen:


<LoginScreen>:
    name: "login"

    BoxLayout:
        orientation: "vertical"
        padding: [30, 40, 30, 30]
        spacing: 18

        canvas.before:
            Color:
                rgba: 0.03, 0.03, 0.05, 1
            Rectangle:
                pos: self.pos
                size: self.size

        Widget:
            size_hint_y: None
            height: 20

        Label:
            text: "MiniSpotify"
            font_size: 30
            bold: True
            color: 1, 1, 1, 1
            size_hint_y: None
            height: 55

        Label:
            text: "Use admin / 123456 to sign in"
            font_size: 16
            color: 0.75, 0.75, 0.8, 1
            size_hint_y: None
            height: 30

        Widget:
            size_hint_y: None
            height: 10

        BoxLayout:
            orientation: "vertical"
            spacing: 14
            size_hint_y: None
            height: 170

            Label:
                text: "Username"
                color: 1, 1, 1, 1
                font_size: 15
                halign: "left"
                text_size: self.size
                size_hint_y: None
                height: 25

            TextInput:
                id: username
                hint_text: "Enter username"
                multiline: False
                background_normal: ""
                background_active: ""
                background_color: 0.18, 0.18, 0.20, 1
                foreground_color: 1, 1, 1, 1
                hint_text_color: 0.65, 0.65, 0.7, 1
                cursor_color: 1, 0.35, 0.75, 1
                padding: [16, 12, 16, 12]
                size_hint_y: None
                height: 48

            Label:
                text: "Password"
                color: 1, 1, 1, 1
                font_size: 15
                halign: "left"
                text_size: self.size
                size_hint_y: None
                height: 25

            TextInput:
                id: password
                hint_text: "Enter password"
                password: True
                multiline: False
                background_normal: ""
                background_active: ""
                background_color: 0.18, 0.18, 0.20, 1
                foreground_color: 1, 1, 1, 1
                hint_text_color: 0.65, 0.65, 0.7, 1
                cursor_color: 1, 0.35, 0.75, 1
                padding: [16, 12, 16, 12]
                size_hint_y: None
                height: 48

        Label:
            id: msg
            text: ""
            color: 1, 0.45, 0.75, 1
            font_size: 14
            size_hint_y: None
            height: 28

        Button:
            text: "Login"
            size_hint_y: None
            height: 50
            background_normal: ""
            background_down: ""
            background_color: 0.35, 0.05, 0.55, 1
            color: 1, 1, 1, 1
            bold: True
            on_release: root.on_login()

        Button:
            text: "Clear"
            size_hint_y: None
            height: 50
            background_normal: ""
            background_down: ""
            background_color: 0.20, 0.20, 0.24, 1
            color: 1, 1, 1, 1
            on_release: root.clear_fields()

        Widget:


<HomeScreen>:
    name: "home"

    BoxLayout:
        orientation: "vertical"

        canvas.before:
            Color:
                rgba: 0.03, 0.03, 0.05, 1
            Rectangle:
                pos: self.pos
                size: self.size

        BoxLayout:
            orientation: "vertical"
            padding: [24, 28, 24, 16]
            spacing: 16

            BoxLayout:
                size_hint_y: None
                height: 44
                spacing: 8

                Label:
                    text: "My Music"
                    font_size: 28
                    bold: True
                    color: 1, 1, 1, 1
                    halign: "left"
                    valign: "middle"
                    text_size: self.size

                Label:
                    text: "Favorite"
                    font_size: 14
                    color: 1, 0.45, 0.75, 1
                    size_hint_x: None
                    width: 80
                    halign: "right"
                    valign: "middle"
                    text_size: self.size

                Button:
                    text: "Logout"
                    size_hint_x: None
                    width: 90
                    background_normal: ""
                    background_down: ""
                    background_color: 0.30, 0.05, 0.45, 1
                    color: 1, 1, 1, 1
                    on_release: root.logout()

            TextInput:
                hint_text: "Search..."
                multiline: False
                background_normal: ""
                background_active: ""
                background_color: 0.20, 0.20, 0.24, 1
                foreground_color: 1, 1, 1, 1
                hint_text_color: 0.65, 0.65, 0.70, 1
                padding: [16, 14, 16, 14]
                size_hint_y: None
                height: 48

            ScrollView:
                do_scroll_x: False
                bar_width: 6

                BoxLayout:
                    orientation: "vertical"
                    size_hint_y: None
                    height: self.minimum_height
                    spacing: 14
                    padding: [0, 6, 0, 12]

                    Label:
                        text: "Trending Now"
                        font_size: 22
                        bold: True
                        color: 1, 1, 1, 1
                        size_hint_y: None
                        height: 36
                        halign: "left"
                        valign: "middle"
                        text_size: self.size

                    Button:
                        size_hint_y: None
                        height: 92
                        background_normal: ""
                        background_down: ""
                        background_color: 0.11, 0.11, 0.14, 1
                        on_release: root.open_player("song_1")

                        BoxLayout:
                            orientation: "horizontal"
                            padding: [12, 12, 12, 12]
                            spacing: 12

                            Label:
                                text: "M"
                                size_hint_x: None
                                width: 52
                                font_size: 20
                                bold: True
                                color: 1, 1, 1, 1
                                halign: "center"
                                valign: "middle"
                                text_size: self.size

                                canvas.before:
                                    Color:
                                        rgba: 0.24, 0.08, 0.35, 1
                                    RoundedRectangle:
                                        pos: self.x + 4, self.y + 8
                                        size: self.width - 8, self.height - 16
                                        radius: [12]

                            BoxLayout:
                                orientation: "vertical"
                                spacing: 2

                                Label:
                                    text: "Midnight Dreams"
                                    color: 1, 1, 1, 1
                                    font_size: 18
                                    bold: True
                                    halign: "left"
                                    valign: "middle"
                                    text_size: self.size

                                Label:
                                    text: "The Dreamers"
                                    color: 0.75, 0.75, 0.80, 1
                                    font_size: 14
                                    halign: "left"
                                    valign: "middle"
                                    text_size: self.size

                            BoxLayout:
                                orientation: "vertical"
                                size_hint_x: None
                                width: 56
                                spacing: 2

                                Label:
                                    text: "#1"
                                    color: 1, 0.45, 0.75, 1
                                    font_size: 15
                                    halign: "right"
                                    valign: "middle"
                                    text_size: self.size

                                Label:
                                    text: "3:45"
                                    color: 0.80, 0.80, 0.85, 1
                                    font_size: 14
                                    halign: "right"
                                    valign: "middle"
                                    text_size: self.size

                    Button:
                        size_hint_y: None
                        height: 92
                        background_normal: ""
                        background_down: ""
                        background_color: 0.11, 0.11, 0.14, 1
                        on_release: root.open_player("song_2")

                        BoxLayout:
                            orientation: "horizontal"
                            padding: [12, 12, 12, 12]
                            spacing: 12

                            Label:
                                text: "S"
                                size_hint_x: None
                                width: 52
                                font_size: 20
                                bold: True
                                color: 1, 1, 1, 1
                                halign: "center"
                                valign: "middle"
                                text_size: self.size

                                canvas.before:
                                    Color:
                                        rgba: 0.24, 0.08, 0.35, 1
                                    RoundedRectangle:
                                        pos: self.x + 4, self.y + 8
                                        size: self.width - 8, self.height - 16
                                        radius: [12]

                            BoxLayout:
                                orientation: "vertical"
                                spacing: 2

                                Label:
                                    text: "Summer Vibes"
                                    color: 1, 1, 1, 1
                                    font_size: 18
                                    bold: True
                                    halign: "left"
                                    valign: "middle"
                                    text_size: self.size

                                Label:
                                    text: "Beach Boys Revival"
                                    color: 0.75, 0.75, 0.80, 1
                                    font_size: 14
                                    halign: "left"
                                    valign: "middle"
                                    text_size: self.size

                            BoxLayout:
                                orientation: "vertical"
                                size_hint_x: None
                                width: 56
                                spacing: 2

                                Label:
                                    text: "#2"
                                    color: 1, 0.45, 0.75, 1
                                    font_size: 15
                                    halign: "right"
                                    valign: "middle"
                                    text_size: self.size

                                Label:
                                    text: "4:12"
                                    color: 0.80, 0.80, 0.85, 1
                                    font_size: 14
                                    halign: "right"
                                    valign: "middle"
                                    text_size: self.size

                    Button:
                        size_hint_y: None
                        height: 92
                        background_normal: ""
                        background_down: ""
                        background_color: 0.11, 0.11, 0.14, 1
                        on_release: root.open_player("song_3")

                        BoxLayout:
                            orientation: "horizontal"
                            padding: [12, 12, 12, 12]
                            spacing: 12

                            Label:
                                text: "E"
                                size_hint_x: None
                                width: 52
                                font_size: 20
                                bold: True
                                color: 1, 1, 1, 1
                                halign: "center"
                                valign: "middle"
                                text_size: self.size

                                canvas.before:
                                    Color:
                                        rgba: 0.24, 0.08, 0.35, 1
                                    RoundedRectangle:
                                        pos: self.x + 4, self.y + 8
                                        size: self.width - 8, self.height - 16
                                        radius: [12]

                            BoxLayout:
                                orientation: "vertical"
                                spacing: 2

                                Label:
                                    text: "Electric Soul"
                                    color: 1, 1, 1, 1
                                    font_size: 18
                                    bold: True
                                    halign: "left"
                                    valign: "middle"
                                    text_size: self.size

                                Label:
                                    text: "Neon Lights"
                                    color: 0.75, 0.75, 0.80, 1
                                    font_size: 14
                                    halign: "left"
                                    valign: "middle"
                                    text_size: self.size

                            BoxLayout:
                                orientation: "vertical"
                                size_hint_x: None
                                width: 56
                                spacing: 2

                                Label:
                                    text: "#3"
                                    color: 1, 0.45, 0.75, 1
                                    font_size: 15
                                    halign: "right"
                                    valign: "middle"
                                    text_size: self.size

                                Label:
                                    text: "3:28"
                                    color: 0.80, 0.80, 0.85, 1
                                    font_size: 14
                                    halign: "right"
                                    valign: "middle"
                                    text_size: self.size

                    Label:
                        text: "Recommended for You"
                        font_size: 22
                        bold: True
                        color: 1, 1, 1, 1
                        size_hint_y: None
                        height: 36
                        halign: "left"
                        valign: "middle"
                        text_size: self.size

                    GridLayout:
                        cols: 3
                        spacing: 14
                        size_hint_y: None
                        height: 130

                        Button:
                            text: "Album 1"
                            background_normal: ""
                            background_down: ""
                            background_color: 0.38, 0.23, 0.08, 1
                            color: 1, 1, 1, 1

                        Button:
                            text: "Album 2"
                            background_normal: ""
                            background_down: ""
                            background_color: 0.38, 0.23, 0.08, 1
                            color: 1, 1, 1, 1

                        Button:
                            text: "Album 3"
                            background_normal: ""
                            background_down: ""
                            background_color: 0.38, 0.23, 0.08, 1
                            color: 1, 1, 1, 1

        BoxLayout:
            size_hint_y: None
            height: 72
            padding: [8, 8, 8, 8]
            spacing: 8

            canvas.before:
                Color:
                    rgba: 0.14, 0.00, 0.25, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

            Button:
                text: "Home"
                background_normal: ""
                background_down: ""
                background_color: 0.45, 0.40, 0.55, 1
                color: 1, 0.4, 0.8, 1
                bold: True
                on_release: root.go_home()

            Button:
                text: "Search"
                background_normal: ""
                background_down: ""
                background_color: 0.14, 0.00, 0.25, 1
                color: 0.85, 0.85, 0.85, 1
                on_release: root.go_search()

            Button:
                text: "Favorite"
                background_normal: ""
                background_down: ""
                background_color: 0.14, 0.00, 0.25, 1
                color: 0.85, 0.85, 0.85, 1
                on_release: root.go_favorite()


<PlayerScreen>:
    name: "player"

    BoxLayout:
        orientation: "vertical"
        padding: [30, 40, 30, 30]
        spacing: 20

        canvas.before:
            Color:
                rgba: 0.03, 0.03, 0.05, 1
            Rectangle:
                pos: self.pos
                size: self.size

        Label:
            text: "Now Playing"
            font_size: 28
            bold: True
            color: 1, 1, 1, 1
            size_hint_y: None
            height: 50

        Widget:
            size_hint_y: None
            height: 10

        Button:
            text: "Song Cover"
            size_hint_y: None
            height: 200
            background_normal: ""
            background_down: ""
            background_color: 0.25, 0.10, 0.35, 1
            color: 1, 1, 1, 1
            bold: True

        Label:
            text: root.song_title
            font_size: 20
            color: 0.85, 0.85, 0.9, 1
            size_hint_y: None
            height: 30

        Label:
            text: root.artist_name
            font_size: 16
            color: 1, 0.45, 0.75, 1
            size_hint_y: None
            height: 25

        BoxLayout:
            size_hint_y: None
            height: 60
            spacing: 12

            Button:
                text: "Prev"
                background_normal: ""
                background_down: ""
                background_color: 0.20, 0.20, 0.24, 1
                color: 1, 1, 1, 1
                on_release: root.on_prev()

            Button:
                text: "Play"
                background_normal: ""
                background_down: ""
                background_color: 0.35, 0.05, 0.55, 1
                color: 1, 1, 1, 1
                on_release: root.on_play()

            Button:
                text: "Pause"
                background_normal: ""
                background_down: ""
                background_color: 0.25, 0.10, 0.35, 1
                color: 1, 1, 1, 1
                on_release: root.on_pause()

            Button:
                text: "Next"
                background_normal: ""
                background_down: ""
                background_color: 0.20, 0.20, 0.24, 1
                color: 1, 1, 1, 1
                on_release: root.on_next()

        Button:
            text: "Back to Home"
            size_hint_y: None
            height: 50
            background_normal: ""
            background_down: ""
            background_color: 0.20, 0.20, 0.24, 1
            color: 1, 1, 1, 1
            on_release: root.back_home()

        Widget:


<SearchScreen>:
    name: "search"

    BoxLayout:
        orientation: "vertical"
        padding: [24, 28, 24, 16]
        spacing: 16

        canvas.before:
            Color:
                rgba: 0.03, 0.03, 0.05, 1
            Rectangle:
                pos: self.pos
                size: self.size

        Label:
            text: "Search"
            font_size: 28
            bold: True
            color: 1, 1, 1, 1
            size_hint_y: None
            height: 44
            halign: "left"
            text_size: self.size

        TextInput:
            hint_text: "Search songs, artists, albums..."
            multiline: False
            background_normal: ""
            background_active: ""
            background_color: 0.18, 0.18, 0.20, 1
            foreground_color: 1, 1, 1, 1
            hint_text_color: 0.65, 0.65, 0.7, 1
            padding: [16, 12, 16, 12]
            size_hint_y: None
            height: 48

        Label:
            text: "Popular Searches"
            font_size: 22
            bold: True
            color: 1, 1, 1, 1
            size_hint_y: None
            height: 36
            halign: "left"
            text_size: self.size

        Button:
            text: "Chill Mix"
            background_normal: ""
            background_down: ""
            background_color: 0.12, 0.12, 0.14, 1
            color: 1, 1, 1, 1

        Button:
            text: "Night Drive"
            background_normal: ""
            background_down: ""
            background_color: 0.12, 0.12, 0.14, 1
            color: 1, 1, 1, 1

        Button:
            text: "Acoustic Mood"
            background_normal: ""
            background_down: ""
            background_color: 0.12, 0.12, 0.14, 1
            color: 1, 1, 1, 1

        Widget:

        BoxLayout:
            size_hint_y: None
            height: 72
            padding: [8, 8, 8, 8]
            spacing: 8

            canvas.before:
                Color:
                    rgba: 0.14, 0.00, 0.25, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

            Button:
                text: "Home"
                background_normal: ""
                background_down: ""
                background_color: 0.14, 0.00, 0.25, 1
                color: 0.85, 0.85, 0.85, 1
                on_release: root.go_home()

            Button:
                text: "Search"
                background_normal: ""
                background_down: ""
                background_color: 0.45, 0.40, 0.55, 1
                color: 1, 0.4, 0.8, 1
                bold: True
                on_release: root.go_search()

            Button:
                text: "Favorite"
                background_normal: ""
                background_down: ""
                background_color: 0.14, 0.00, 0.25, 1
                color: 0.85, 0.85, 0.85, 1
                on_release: root.go_favorite()


<FavoriteScreen>:
    name: "favorite"

    BoxLayout:
        orientation: "vertical"
        padding: [24, 28, 24, 16]
        spacing: 16

        canvas.before:
            Color:
                rgba: 0.03, 0.03, 0.05, 1
            Rectangle:
                pos: self.pos
                size: self.size

        Label:
            text: "Favorite"
            font_size: 28
            bold: True
            color: 1, 1, 1, 1
            size_hint_y: None
            height: 44
            halign: "left"
            text_size: self.size

        Label:
            text: "Your liked songs"
            font_size: 16
            color: 0.75, 0.75, 0.8, 1
            size_hint_y: None
            height: 24
            halign: "left"
            text_size: self.size

        Button:
            text: "Midnight Dreams"
            background_normal: ""
            background_down: ""
            background_color: 0.12, 0.12, 0.14, 1
            color: 1, 1, 1, 1
            on_release: root.open_player("song_1")

        Button:
            text: "Electric Soul"
            background_normal: ""
            background_down: ""
            background_color: 0.12, 0.12, 0.14, 1
            color: 1, 1, 1, 1
            on_release: root.open_player("song_3")

        Button:
            text: "Summer Vibes"
            background_normal: ""
            background_down: ""
            background_color: 0.12, 0.12, 0.14, 1
            color: 1, 1, 1, 1
            on_release: root.open_player("song_2")

        Widget:

        BoxLayout:
            size_hint_y: None
            height: 72
            padding: [8, 8, 8, 8]
            spacing: 8

            canvas.before:
                Color:
                    rgba: 0.14, 0.00, 0.25, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

            Button:
                text: "Home"
                background_normal: ""
                background_down: ""
                background_color: 0.14, 0.00, 0.25, 1
                color: 0.85, 0.85, 0.85, 1
                on_release: root.go_home()

            Button:
                text: "Search"
                background_normal: ""
                background_down: ""
                background_color: 0.14, 0.00, 0.25, 1
                color: 0.85, 0.85, 0.85, 1
                on_release: root.go_search()

            Button:
                text: "Favorite"
                background_normal: ""
                background_down: ""
                background_color: 0.45, 0.40, 0.55, 1
                color: 1, 0.4, 0.8, 1
                bold: True
                on_release: root.go_favorite()