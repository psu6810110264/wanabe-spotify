#:kivy 2.3.0

RootWidget:
    LoginScreen:
    HomeScreen:
    PlayerScreen:
    SearchScreen:
    FavoriteScreen:

<LoginScreen>:
    name: "login"

    BoxLayout:
        orientation: "vertical"
        padding: [30, 40, 30, 30]
        spacing: 18

        canvas.before:
            Color:
                rgba: 0.03, 0.03, 0.05, 1
            Rectangle:
                pos: self.pos
                size: self.size

        Widget:
            size_hint_y: None
            height: 20

        Label:
            text: "MiniSpotify"
            font_size: 30
            bold: True
            color: 1, 1, 1, 1
            size_hint_y: None
            height: 55

        Label:
            text: "Use admin / 123456 to sign in"
            font_size: 16
            color: 0.75, 0.75, 0.8, 1
            size_hint_y: None
            height: 30

        Widget:
            size_hint_y: None
            height: 10

        BoxLayout:
            orientation: "vertical"
            spacing: 14
            size_hint_y: None
            height: 170

            Label:
                text: "Username"
                color: 1, 1, 1, 1
                font_size: 15
                halign: "left"
                text_size: self.size
                size_hint_y: None
                height: 25

            TextInput:
                id: username
                hint_text: "Enter username"
                multiline: False
                background_normal: ""
                background_active: ""
                background_color: 0.18, 0.18, 0.20, 1
                foreground_color: 1, 1, 1, 1
                hint_text_color: 0.65, 0.65, 0.7, 1
                cursor_color: 1, 0.35, 0.75, 1
                padding: [16, 12, 16, 12]
                size_hint_y: None
                height: 48

            Label:
                text: "Password"
                color: 1, 1, 1, 1
                font_size: 15
                halign: "left"
                text_size: self.size
                size_hint_y: None
                height: 25

            TextInput:
                id: password
                hint_text: "Enter password"
                password: True
                multiline: False
                background_normal: ""
                background_active: ""
                background_color: 0.18, 0.18, 0.20, 1
                foreground_color: 1, 1, 1, 1
                hint_text_color: 0.65, 0.65, 0.7, 1
                cursor_color: 1, 0.35, 0.75, 1
                padding: [16, 12, 16, 12]
                size_hint_y: None
                height: 48

        Label:
            id: msg
            text: ""
            color: 1, 0.45, 0.75, 1
            font_size: 14
            size_hint_y: None
            height: 28

        Button:
            text: "Login"
            size_hint_y: None
            height: 50
            background_normal: ""
            background_down: ""
            background_color: 0.35, 0.05, 0.55, 1
            color: 1, 1, 1, 1
            bold: True
            on_release: root.on_login()

        Button:
            text: "Clear"
            size_hint_y: None
            height: 50
            background_normal: ""
            background_down: ""
            background_color: 0.20, 0.20, 0.24, 1
            color: 1, 1, 1, 1
            on_release: root.clear_fields()

        Widget:


<HomeScreen>:
    name: "home"

    BoxLayout:
        orientation: "vertical"

        canvas.before:
            Color:
                rgba: 0.03, 0.03, 0.05, 1
            Rectangle:
                pos: self.pos
                size: self.size

        ScrollView:
            do_scroll_x: False

            BoxLayout:
                orientation: "vertical"
                size_hint_y: None
                height: self.minimum_height
                padding: [25, 35, 25, 20]
                spacing: 18

                BoxLayout:
                    size_hint_y: None
                    height: 50
                    spacing: 10

                    Label:
                        text: "♫"
                        font_size: 28
                        color: 1, 0.4, 0.8, 1
                        size_hint_x: None
                        width: 40

                    Label:
                        text: "My Music"
                        font_size: 28
                        bold: True
                        color: 1, 1, 1, 1
                        halign: "left"
                        valign: "middle"
                        text_size: self.size

                    Label:
                        text: "♡"
                        font_size: 26
                        color: 1, 1, 1, 1
                        size_hint_x: None
                        width: 40
                        halign: "right"
                        valign: "middle"
                        text_size: self.size

                TextInput:
                    hint_text: "Search..."
                    multiline: False
                    background_normal: ""
                    background_active: ""
                    background_color: 0.20, 0.20, 0.22, 1
                    foreground_color: 1, 1, 1, 1
                    hint_text_color: 0.60, 0.60, 0.65, 1
                    padding: [18, 14, 18, 14]
                    size_hint_y: None
                    height: 54

                BoxLayout:
                    size_hint_y: None
                    height: 35
                    spacing: 8

                    Label:
                        text: "↗"
                        font_size: 22
                        color: 1, 0.4, 0.8, 1
                        size_hint_x: None
                        width: 25

                    Label:
                        text: "Trending Now"
                        font_size: 22
                        bold: True
                        color: 1, 1, 1, 1
                        halign: "left"
                        text_size: self.size

                Button:
                    size_hint_y: None
                    height: 90
                    background_normal: ""
                    background_down: ""
                    background_color: 0, 0, 0, 0
                    on_release: root.open_player("song_1")

                    BoxLayout:
                        padding: [12, 12, 12, 12]
                        spacing: 12

                        canvas.before:
                            Color:
                                rgba: 0.11, 0.11, 0.13, 1
                            RoundedRectangle:
                                pos: self.pos
                                size: self.size
                                radius: [18]

                        Label:
                            text: "☾"
                            font_size: 28
                            color: 1, 1, 1, 1
                            size_hint_x: None
                            width: 60

                            canvas.before:
                                Color:
                                    rgba: 0.24, 0.08, 0.35, 1
                                RoundedRectangle:
                                    pos: self.x + 2, self.y + 8
                                    size: self.width - 4, self.height - 16
                                    radius: [12]

                        BoxLayout:
                            orientation: "vertical"
                            spacing: 4

                            Label:
                                text: "Midnight Dreams"
                                color: 1, 1, 1, 1
                                bold: True
                                font_size: 18
                                halign: "left"
                                valign: "middle"
                                text_size: self.size

                            Label:
                                text: "The Dreamers"
                                color: 0.75, 0.75, 0.78, 1
                                font_size: 15
                                halign: "left"
                                valign: "middle"
                                text_size: self.size

                        BoxLayout:
                            orientation: "vertical"
                            size_hint_x: None
                            width: 60
                            spacing: 4

                            Label:
                                text: "#1"
                                color: 0.85, 0.45, 1, 1
                                font_size: 16
                                halign: "right"
                                valign: "middle"
                                text_size: self.size

                            Label:
                                text: "3:45"
                                color: 0.80, 0.80, 0.85, 1
                                font_size: 15
                                halign: "right"
                                valign: "middle"
                                text_size: self.size

                Button:
                    size_hint_y: None
                    height: 90
                    background_normal: ""
                    background_down: ""
                    background_color: 0, 0, 0, 0
                    on_release: root.open_player("song_2")

                    BoxLayout:
                        padding: [12, 12, 12, 12]
                        spacing: 12

                        canvas.before:
                            Color:
                                rgba: 0.11, 0.11, 0.13, 1
                            RoundedRectangle:
                                pos: self.pos
                                size: self.size
                                radius: [18]

                        Label:
                            text: "☂"
                            font_size: 28
                            color: 1, 1, 1, 1
                            size_hint_x: None
                            width: 60

                            canvas.before:
                                Color:
                                    rgba: 0.24, 0.08, 0.35, 1
                                RoundedRectangle:
                                    pos: self.x + 2, self.y + 8
                                    size: self.width - 4, self.height - 16
                                    radius: [12]

                        BoxLayout:
                            orientation: "vertical"
                            spacing: 4

                            Label:
                                text: "Summer Vibes"
                                color: 1, 1, 1, 1
                                bold: True
                                font_size: 18
                                halign: "left"
                                valign: "middle"
                                text_size: self.size

                            Label:
                                text: "Beach Boys Revival"
                                color: 0.75, 0.75, 0.78, 1
                                font_size: 15
                                halign: "left"
                                valign: "middle"
                                text_size: self.size

                        BoxLayout:
                            orientation: "vertical"
                            size_hint_x: None
                            width: 60
                            spacing: 4

                            Label:
                                text: "#2"
                                color: 0.85, 0.45, 1, 1
                                font_size: 16
                                halign: "right"
                                valign: "middle"
                                text_size: self.size

                            Label:
                                text: "4:12"
                                color: 0.80, 0.80, 0.85, 1
                                font_size: 15
                                halign: "right"
                                valign: "middle"
                                text_size: self.size

                Button:
                    size_hint_y: None
                    height: 90
                    background_normal: ""
                    background_down: ""
                    background_color: 0, 0, 0, 0
                    on_release: root.open_player("song_3")

                    BoxLayout:
                        padding: [12, 12, 12, 12]
                        spacing: 12

                        canvas.before:
                            Color:
                                rgba: 0.11, 0.11, 0.13, 1
                            RoundedRectangle:
                                pos: self.pos
                                size: self.size
                                radius: [18]

                        Label:
                            text: "⚡"
                            font_size: 28
                            color: 1, 1, 1, 1
                            size_hint_x: None
                            width: 60

                            canvas.before:
                                Color:
                                    rgba: 0.24, 0.08, 0.35, 1
                                RoundedRectangle:
                                    pos: self.x + 2, self.y + 8
                                    size: self.width - 4, self.height - 16
                                    radius: [12]

                        BoxLayout:
                            orientation: "vertical"
                            spacing: 4

                            Label:
                                text: "Electric Soul"
                                color: 1, 1, 1, 1
                                bold: True
                                font_size: 18
                                halign: "left"
                                valign: "middle"
                                text_size: self.size

                            Label:
                                text: "Neon Lights"
                                color: 0.75, 0.75, 0.78, 1
                                font_size: 15
                                halign: "left"
                                valign: "middle"
                                text_size: self.size

                        BoxLayout:
                            orientation: "vertical"
                            size_hint_x: None
                            width: 60
                            spacing: 4

                            Label:
                                text: "#3"
                                color: 0.85, 0.45, 1, 1
                                font_size: 16
                                halign: "right"
                                valign: "middle"
                                text_size: self.size

                            Label:
                                text: "3:28"
                                color: 0.80, 0.80, 0.85, 1
                                font_size: 15
                                halign: "right"
                                valign: "middle"
                                text_size: self.size

                Label:
                    text: "Recommended for You"
                    font_size: 22
                    bold: True
                    color: 1, 1, 1, 1
                    size_hint_y: None
                    height: 35
                    halign: "left"
                    text_size: self.size

                GridLayout:
                    cols: 3
                    spacing: 14
                    size_hint_y: None
                    height: 150

                    Button:
                        text: "Album 1"
                        background_normal: ""
                        background_down: ""
                        background_color: 0.38, 0.23, 0.08, 1
                        color: 1, 1, 1, 1

                    Button:
                        text: "Album 2"
                        background_normal: ""
                        background_down: ""
                        background_color: 0.38, 0.23, 0.08, 1
                        color: 1, 1, 1, 1

                    Button:
                        text: "Album 3"
                        background_normal: ""
                        background_down: ""
                        background_color: 0.38, 0.23, 0.08, 1
                        color: 1, 1, 1, 1

                Widget:
                    size_hint_y: None
                    height: 12

        BoxLayout:
            size_hint_y: None
            height: 80
            padding: [10, 10, 10, 10]
            spacing: 10

            canvas.before:
                Color:
                    rgba: 0.14, 0.00, 0.25, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

            Button:
                text: "Home"
                background_normal: ""
                background_down: ""
                background_color: 0.45, 0.40, 0.55, 1
                color: 1, 0.4, 0.8, 1
                bold: True
                on_release: app.root.current = "home"

            Button:
                text: "Search"
                background_normal: ""
                background_down: ""
                background_color: 0.14, 0.00, 0.25, 1
                color: 0.85, 0.85, 0.85, 1
                on_release: app.root.current = "search"

            Button:
                text: "Favorite"
                background_normal: ""
                background_down: ""
                background_color: 0.14, 0.00, 0.25, 1
                color: 0.85, 0.85, 0.85, 1
                on_release: app.root.current = "favorite"


<PlayerScreen>:
    name: "player"

    BoxLayout:
        orientation: "vertical"
        padding: [30, 40, 30, 30]
        spacing: 20

        canvas.before:
            Color:
                rgba: 0.03, 0.03, 0.05, 1
            Rectangle:
                pos: self.pos
                size: self.size

        Label:
            text: "Now Playing"
            font_size: 28
            bold: True
            color: 1, 1, 1, 1
            size_hint_y: None
            height: 50

        Widget:
            size_hint_y: None
            height: 10

        Button:
            text: "Midnight Dreams"
            size_hint_y: None
            height: 200
            background_normal: ""
            background_down: ""
            background_color: 0.25, 0.10, 0.35, 1
            color: 1, 1, 1, 1
            bold: True

        Label:
            text: "The Dreamers"
            font_size: 20
            color: 0.85, 0.85, 0.9, 1
            size_hint_y: None
            height: 30

        Label:
            text: "3:45"
            font_size: 16
            color: 1, 0.45, 0.75, 1
            size_hint_y: None
            height: 25

        BoxLayout:
            size_hint_y: None
            height: 60
            spacing: 12

            Button:
                text: "Prev"
                background_normal: ""
                background_down: ""
                background_color: 0.20, 0.20, 0.24, 1
                color: 1, 1, 1, 1
                on_release: root.on_prev()

            Button:
                text: "Play"
                background_normal: ""
                background_down: ""
                background_color: 0.35, 0.05, 0.55, 1
                color: 1, 1, 1, 1
                on_release: root.on_play()

            Button:
                text: "Pause"
                background_normal: ""
                background_down: ""
                background_color: 0.25, 0.10, 0.35, 1
                color: 1, 1, 1, 1
                on_release: root.on_pause()

            Button:
                text: "Next"
                background_normal: ""
                background_down: ""
                background_color: 0.20, 0.20, 0.24, 1
                color: 1, 1, 1, 1
                on_release: root.on_next()

        Button:
            text: "Back to Home"
            size_hint_y: None
            height: 50
            background_normal: ""
            background_down: ""
            background_color: 0.20, 0.20, 0.24, 1
            color: 1, 1, 1, 1
            on_release: root.back_home()

        Widget:


<SearchScreen>:
    name: "search"

    BoxLayout:
        orientation: "vertical"

        canvas.before:
            Color:
                rgba: 0.03, 0.03, 0.05, 1
            Rectangle:
                pos: self.pos
                size: self.size

        BoxLayout:
            orientation: "vertical"
            padding: [25, 35, 25, 20]
            spacing: 18

            Label:
                text: "Search"
                font_size: 28
                bold: True
                color: 1, 1, 1, 1
                size_hint_y: None
                height: 45
                halign: "left"
                text_size: self.size

            TextInput:
                hint_text: "Search songs, artists, albums..."
                multiline: False
                background_normal: ""
                background_active: ""
                background_color: 0.18, 0.18, 0.20, 1
                foreground_color: 1, 1, 1, 1
                hint_text_color: 0.65, 0.65, 0.7, 1
                padding: [16, 12, 16, 12]
                size_hint_y: None
                height: 50

            Label:
                text: "Popular Searches"
                font_size: 22
                bold: True
                color: 1, 1, 1, 1
                size_hint_y: None
                height: 40
                halign: "left"
                text_size: self.size

            Button:
                text: "Chill Mix"
                background_normal: ""
                background_down: ""
                background_color: 0.12, 0.12, 0.14, 1
                color: 1, 1, 1, 1

            Button:
                text: "Night Drive"
                background_normal: ""
                background_down: ""
                background_color: 0.12, 0.12, 0.14, 1
                color: 1, 1, 1, 1

            Button:
                text: "Acoustic Mood"
                background_normal: ""
                background_down: ""
                background_color: 0.12, 0.12, 0.14, 1
                color: 1, 1, 1, 1

            Widget:

        BoxLayout:
            size_hint_y: None
            height: 80
            padding: [10, 10, 10, 10]
            spacing: 10

            canvas.before:
                Color:
                    rgba: 0.14, 0.00, 0.25, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

            Button:
                text: "Home"
                background_normal: ""
                background_down: ""
                background_color: 0.14, 0.00, 0.25, 1
                color: 0.85, 0.85, 0.85, 1
                on_release: app.root.current = "home"

            Button:
                text: "Search"
                background_normal: ""
                background_down: ""
                background_color: 0.45, 0.40, 0.55, 1
                color: 1, 0.4, 0.8, 1
                bold: True
                on_release: app.root.current = "search"

            Button:
                text: "Favorite"
                background_normal: ""
                background_down: ""
                background_color: 0.14, 0.00, 0.25, 1
                color: 0.85, 0.85, 0.85, 1
                on_release: app.root.current = "favorite"


<FavoriteScreen>:
    name: "favorite"

    BoxLayout:
        orientation: "vertical"

        canvas.before:
            Color:
                rgba: 0.03, 0.03, 0.05, 1
            Rectangle:
                pos: self.pos
                size: self.size

        BoxLayout:
            orientation: "vertical"
            padding: [25, 35, 25, 20]
            spacing: 18

            Label:
                text: "Favorite"
                font_size: 28
                bold: True
                color: 1, 1, 1, 1
                size_hint_y: None
                height: 45
                halign: "left"
                text_size: self.size

            Label:
                text: "Your liked songs"
                font_size: 16
                color: 0.75, 0.75, 0.8, 1
                size_hint_y: None
                height: 25
                halign: "left"
                text_size: self.size

            Button:
                text: "Midnight Dreams"
                background_normal: ""
                background_down: ""
                background_color: 0.12, 0.12, 0.14, 1
                color: 1, 1, 1, 1
                on_release: app.root.current = "player"

            Button:
                text: "Electric Soul"
                background_normal: ""
                background_down: ""
                background_color: 0.12, 0.12, 0.14, 1
                color: 1, 1, 1, 1
                on_release: app.root.current = "player"

            Button:
                text: "Summer Vibes"
                background_normal: ""
                background_down: ""
                background_color: 0.12, 0.12, 0.14, 1
                color: 1, 1, 1, 1
                on_release: app.root.current = "player"

            Widget:

        BoxLayout:
            size_hint_y: None
            height: 80
            padding: [10, 10, 10, 10]
            spacing: 10

            canvas.before:
                Color:
                    rgba: 0.14, 0.00, 0.25, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

            Button:
                text: "Home"
                background_normal: ""
                background_down: ""
                background_color: 0.14, 0.00, 0.25, 1
                color: 0.85, 0.85, 0.85, 1
                on_release: app.root.current = "home"

            Button:
                text: "Search"
                background_normal: ""
                background_down: ""
                background_color: 0.14, 0.00, 0.25, 1
                color: 0.85, 0.85, 0.85, 1
                on_release: app.root.current = "search"

            Button:
                text: "Favorite"
                background_normal: ""
                background_down: ""
                background_color: 0.45, 0.40, 0.55, 1
                color: 1, 0.4, 0.8, 1
                bold: True
                on_release: app.root.current = "favorite"