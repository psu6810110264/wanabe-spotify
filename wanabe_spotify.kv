#:kivy 2.3.0
#:import dp kivy.metrics.dp

RootWidget:
    current: "login"
    LoginScreen:
    RegisterScreen:
    ProfileScreen:
    AddSongScreen:
    HomeScreen:
    PlayerScreen:
    SearchScreen:
    FavoriteScreen:


<SongCard>:
    orientation: "horizontal"
    size_hint_y: None
    height: dp(76)
    padding: [dp(10), dp(10), dp(10), dp(10)]
    spacing: dp(12)
    radius: [10,]
    ripple_behavior: True
    md_bg_color: 1, 1, 1, .05
    elevation: 0

    MDCard:
        size_hint: None, None
        size: dp(50), dp(50)
        radius: [8,]
        md_bg_color: .2, .1, .3, 1
        pos_hint: {"center_y": .5}

        MDLabel:
            text: "♪"
            halign: "center"
            valign: "middle"
            theme_text_color: "Custom"
            text_color: 1, 1, 1, 1
            font_style: "H6"

    MDBoxLayout:
        orientation: "vertical"
        size_hint_x: 1
        spacing: dp(2)
        padding: [0, dp(4), 0, dp(4)]
        pos_hint: {"center_y": .5}

        MDLabel:
            text: root.title
            theme_text_color: "Custom"
            text_color: 1, 1, 1, 1
            bold: True
            size_hint_y: None
            height: dp(24)
            shorten: True
            shorten_from: "right"

        MDLabel:
            text: root.artist
            theme_text_color: "Custom"
            text_color: .78, .78, .84, 1
            size_hint_y: None
            height: dp(20)
            font_style: "Caption"
            shorten: True
            shorten_from: "right"

    MDBoxLayout:
        orientation: "vertical"
        size_hint_x: None
        width: dp(50)
        spacing: dp(2)
        padding: [0, dp(4), 0, dp(4)]
        pos_hint: {"center_y": .5}

        MDLabel:
            text: root.rank
            halign: "right"
            theme_text_color: "Custom"
            text_color: .85, .65, 1, 1
            size_hint_y: None
            height: dp(20)
            font_style: "Caption"

        MDLabel:
            text: root.duration
            halign: "right"
            theme_text_color: "Custom"
            text_color: .8, .8, .8, 1
            size_hint_y: None
            height: dp(20)
            font_style: "Caption"


<RecommendCard>:
    orientation: "vertical"
    size_hint: None, None
    size: dp(110), dp(150)
    spacing: dp(5)
    md_bg_color: 0, 0, 0, 0
    elevation: 0

    MDCard:
        size_hint: None, None
        size: dp(110), dp(110)
        radius: [15,]
        md_bg_color: .3, .2, .1, 1

        MDIcon:
            icon: root.image_icon
            halign: "center"
            font_size: dp(50)
            pos_hint: {"center_y": .5}
            theme_text_color: "Custom"
            text_color: 1, 1, 1, 1

    MDLabel:
        text: root.title
        font_style: "Subtitle2"
        theme_text_color: "Custom"
        text_color: 1, 1, 1, 1
        shorten: True
        shorten_from: "right"

    MDLabel:
        text: root.subtitle
        font_style: "Caption"
        theme_text_color: "Custom"
        text_color: .7, .7, .7, 1
        shorten: True


<LoginScreen>:
    name: "login"
    md_bg_color: .07, .04, .14, 1

    MDBoxLayout:
        orientation: "vertical"
        padding: [dp(28), dp(40), dp(28), dp(28)]
        spacing: dp(14)

        Widget:
            size_hint_y: None
            height: dp(10)

        MDCard:
            size_hint: None, None
            size: dp(90), dp(90)
            radius: [45,]
            elevation: 0
            md_bg_color: .78, .32, .72, 1
            pos_hint: {"center_x": .5}

            MDLabel:
                text: "♫"
                halign: "center"
                valign: "middle"
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1
                font_style: "H3"

        MDLabel:
            text: "grape music"
            font_style: "H4"
            bold: True
            halign: "center"
            theme_text_color: "Custom"
            text_color: 1, 1, 1, 1
            size_hint_y: None
            height: dp(55)

        MDLabel:
            text: "Use admin / 123456 or create a new account"
            font_style: "Caption"
            halign: "center"
            theme_text_color: "Custom"
            text_color: .78, .78, .85, 1
            size_hint_y: None
            height: dp(28)

        Widget:
            size_hint_y: None
            height: dp(8)

        MDCard:
            orientation: "vertical"
            padding: dp(16)
            spacing: dp(14)
            size_hint_y: None
            height: dp(210)
            radius: [18,]
            elevation: 0
            md_bg_color: 1, 1, 1, .06

            MDLabel:
                text: "Username"
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1
                size_hint_y: None
                height: dp(22)

            TextInput:
                id: username
                hint_text: "Enter username"
                multiline: False
                background_normal: ""
                background_active: ""
                background_color: 1, 1, 1, .08
                foreground_color: 1, 1, 1, 1
                hint_text_color: .68, .68, .76, 1
                cursor_color: 1, .45, .75, 1
                padding: [dp(16), dp(12), dp(16), dp(12)]
                size_hint_y: None
                height: dp(46)

            MDLabel:
                text: "Password"
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1
                size_hint_y: None
                height: dp(22)

            TextInput:
                id: password
                hint_text: "Enter password"
                password: True
                multiline: False
                background_normal: ""
                background_active: ""
                background_color: 1, 1, 1, .08
                foreground_color: 1, 1, 1, 1
                hint_text_color: .68, .68, .76, 1
                cursor_color: 1, .45, .75, 1
                padding: [dp(16), dp(12), dp(16), dp(12)]
                size_hint_y: None
                height: dp(46)

        MDLabel:
            id: msg
            text: ""
            halign: "center"
            theme_text_color: "Custom"
            text_color: 1, .45, .75, 1
            size_hint_y: None
            height: dp(26)

        MDRaisedButton:
            text: "Login"
            md_bg_color: .78, .32, .72, 1
            text_color: 1, 1, 1, 1
            size_hint_y: None
            height: dp(46)
            on_release: root.on_login()

        MDRectangleFlatButton:
            text: "Create Account"
            text_color: 1, 1, 1, 1
            line_color: .78, .32, .72, 1
            size_hint_y: None
            height: dp(46)
            on_release: root.go_register()

        MDRectangleFlatButton:
            text: "Clear"
            text_color: 1, 1, 1, 1
            line_color: .65, .55, .78, 1
            size_hint_y: None
            height: dp(46)
            on_release: root.clear_fields()

        Widget:


<RegisterScreen>:
    name: "register"
    md_bg_color: .07, .04, .14, 1

    MDBoxLayout:
        orientation: "vertical"
        padding: [dp(28), dp(32), dp(28), dp(24)]
        spacing: dp(12)

        MDBoxLayout:
            adaptive_height: True

            MDIconButton:
                icon: "arrow-left"
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1
                on_release: root.go_login()

            Widget:

        MDLabel:
            text: "Create Account"
            font_style: "H5"
            bold: True
            halign: "center"
            theme_text_color: "Custom"
            text_color: 1, 1, 1, 1
            size_hint_y: None
            height: dp(42)

        MDLabel:
            text: "Create a username and password to login"
            font_style: "Caption"
            halign: "center"
            theme_text_color: "Custom"
            text_color: .78, .78, .85, 1
            size_hint_y: None
            height: dp(26)

        MDCard:
            orientation: "vertical"
            padding: dp(16)
            spacing: dp(12)
            size_hint_y: None
            height: dp(290)
            radius: [18,]
            elevation: 0
            md_bg_color: 1, 1, 1, .06

            MDLabel:
                text: "Username"
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1
                size_hint_y: None
                height: dp(20)

            TextInput:
                id: reg_username
                hint_text: "Enter username"
                multiline: False
                background_normal: ""
                background_active: ""
                background_color: 1, 1, 1, .08
                foreground_color: 1, 1, 1, 1
                hint_text_color: .68, .68, .76, 1
                cursor_color: 1, .45, .75, 1
                padding: [dp(16), dp(12), dp(16), dp(12)]
                size_hint_y: None
                height: dp(46)

            MDLabel:
                text: "Password"
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1
                size_hint_y: None
                height: dp(20)

            TextInput:
                id: reg_password
                hint_text: "Enter password"
                password: True
                multiline: False
                background_normal: ""
                background_active: ""
                background_color: 1, 1, 1, .08
                foreground_color: 1, 1, 1, 1
                hint_text_color: .68, .68, .76, 1
                cursor_color: 1, .45, .75, 1
                padding: [dp(16), dp(12), dp(16), dp(12)]
                size_hint_y: None
                height: dp(46)

            MDLabel:
                text: "Confirm Password"
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1
                size_hint_y: None
                height: dp(20)

            TextInput:
                id: reg_confirm_password
                hint_text: "Re-enter password"
                password: True
                multiline: False
                background_normal: ""
                background_active: ""
                background_color: 1, 1, 1, .08
                foreground_color: 1, 1, 1, 1
                hint_text_color: .68, .68, .76, 1
                cursor_color: 1, .45, .75, 1
                padding: [dp(16), dp(12), dp(16), dp(12)]
                size_hint_y: None
                height: dp(46)

        MDLabel:
            id: reg_msg
            text: ""
            halign: "center"
            theme_text_color: "Custom"
            text_color: 1, .45, .75, 1
            size_hint_y: None
            height: dp(26)

        MDRaisedButton:
            text: "Create Account"
            md_bg_color: .78, .32, .72, 1
            text_color: 1, 1, 1, 1
            size_hint_y: None
            height: dp(46)
            on_release: root.on_create_account()

        MDRectangleFlatButton:
            text: "Clear"
            text_color: 1, 1, 1, 1
            line_color: .65, .55, .78, 1
            size_hint_y: None
            height: dp(46)
            on_release: root.clear_fields()

        MDRectangleFlatButton:
            text: "Back to Login"
            text_color: 1, 1, 1, 1
            line_color: .78, .32, .72, 1
            size_hint_y: None
            height: dp(46)
            on_release: root.go_login()

        Widget:


<ProfileScreen>:
    name: "profile"
    md_bg_color: .10, .06, .17, 1

    MDBoxLayout:
        orientation: "vertical"
        padding: [dp(18), dp(16), dp(18), dp(16)]
        spacing: dp(14)

        MDBoxLayout:
            adaptive_height: True

            MDIconButton:
                icon: "arrow-left"
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1
                on_release: root.go_home()

            MDLabel:
                text: "Profile"
                font_style: "H6"
                bold: True
                halign: "center"
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1

            Widget:
                size_hint_x: None
                width: dp(48)

        MDCard:
            orientation: "vertical"
            size_hint_y: None
            height: dp(260)
            radius: [24,]
            elevation: 0
            padding: [dp(20), dp(20), dp(20), dp(20)]
            spacing: dp(14)
            md_bg_color: .18, .13, .31, 1

            MDCard:
                size_hint: None, None
                size: dp(88), dp(88)
                radius: [44,]
                elevation: 0
                md_bg_color: .78, .32, .72, 1
                pos_hint: {"center_x": .5}

                MDIcon:
                    icon: "account"
                    halign: "center"
                    pos_hint: {"center_x": .5, "center_y": .5}
                    font_size: "42sp"
                    theme_text_color: "Custom"
                    text_color: 1, 1, 1, 1

            MDLabel:
                text: root.profile_username
                halign: "center"
                font_style: "H6"
                bold: True
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1

            MDLabel:
                text: root.profile_stats
                halign: "center"
                font_style: "Subtitle2"
                theme_text_color: "Custom"
                text_color: .78, .78, .86, 1

            MDRaisedButton:
                text: "Back to Home"
                md_bg_color: .78, .32, .72, 1
                text_color: 1, 1, 1, 1
                pos_hint: {"center_x": .5}
                on_release: root.go_home()

        MDCard:
            orientation: "vertical"
            size_hint_y: None
            height: dp(132)
            radius: [18,]
            elevation: 0
            padding: [dp(16), dp(14), dp(16), dp(14)]
            spacing: dp(8)
            md_bg_color: 1, 1, 1, .06

            MDLabel:
                text: "Account"
                bold: True
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1

            MDLabel:
                text: "Signed in as " + root.profile_username
                theme_text_color: "Custom"
                text_color: .78, .78, .86, 1

            MDLabel:
                text: "You can logout from Home screen."
                theme_text_color: "Custom"
                text_color: .72, .72, .8, 1

        Widget:


<AddSongScreen>:
    name: "add_song"
    md_bg_color: .10, .06, .17, 1

    MDBoxLayout:
        orientation: "vertical"
        padding: [dp(18), dp(16), dp(18), dp(16)]
        spacing: dp(12)

        MDBoxLayout:
            adaptive_height: True

            MDIconButton:
                icon: "arrow-left"
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1
                on_release: root.go_home()

            MDLabel:
                text: "Add Song"
                font_style: "H6"
                bold: True
                halign: "center"
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1

            Widget:
                size_hint_x: None
                width: dp(48)

        MDCard:
            orientation: "vertical"
            padding: dp(14)
            spacing: dp(10)
            size_hint_y: None
            height: dp(472)
            radius: [18,]
            elevation: 0
            md_bg_color: 1, 1, 1, .06

            MDLabel:
                text: "Song Title"
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1
                size_hint_y: None
                height: dp(20)

            TextInput:
                id: new_song_title
                hint_text: "e.g. Sunset Drive"
                multiline: False
                background_normal: ""
                background_active: ""
                background_color: 1, 1, 1, .08
                foreground_color: 1, 1, 1, 1
                hint_text_color: .68, .68, .76, 1
                cursor_color: 1, .45, .75, 1
                padding: [dp(16), dp(12), dp(16), dp(12)]
                size_hint_y: None
                height: dp(46)

            MDLabel:
                text: "Artist"
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1
                size_hint_y: None
                height: dp(20)

            TextInput:
                id: new_song_artist
                hint_text: "e.g. Luna Wave"
                multiline: False
                background_normal: ""
                background_active: ""
                background_color: 1, 1, 1, .08
                foreground_color: 1, 1, 1, 1
                hint_text_color: .68, .68, .76, 1
                cursor_color: 1, .45, .75, 1
                padding: [dp(16), dp(12), dp(16), dp(12)]
                size_hint_y: None
                height: dp(46)

            MDLabel:
                text: "Duration (m:ss)"
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1
                size_hint_y: None
                height: dp(20)

            TextInput:
                id: new_song_duration
                hint_text: "e.g. 3:42"
                multiline: False
                background_normal: ""
                background_active: ""
                background_color: 1, 1, 1, .08
                foreground_color: 1, 1, 1, 1
                hint_text_color: .68, .68, .76, 1
                cursor_color: 1, .45, .75, 1
                padding: [dp(16), dp(12), dp(16), dp(12)]
                size_hint_y: None
                height: dp(46)

            MDLabel:
                text: "Category"
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1
                size_hint_y: None
                height: dp(20)

            Spinner:
                id: new_song_category
                text: "Select category"
                values: ["Pop", "Rock", "Hip Hop", "R&B", "Indie", "EDM", "Jazz", "Acoustic", "Lo-fi", "Other"]
                size_hint_y: None
                height: dp(46)
                background_color: .24, .16, .39, 1
                color: 1, 1, 1, 1

            MDLabel:
                text: "Cover Image"
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1
                size_hint_y: None
                height: dp(20)

            MDBoxLayout:
                adaptive_height: True
                spacing: dp(8)

                MDRaisedButton:
                    text: "Upload Image"
                    md_bg_color: .49, .29, .68, 1
                    text_color: 1, 1, 1, 1
                    size_hint_x: None
                    width: dp(130)
                    on_release: root.pick_cover_image()

                MDLabel:
                    id: cover_path_label
                    text: "No image selected"
                    theme_text_color: "Custom"
                    text_color: .78, .78, .86, 1
                    shorten: True

            MDLabel:
                text: "Song File"
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1
                size_hint_y: None
                height: dp(20)

            MDBoxLayout:
                adaptive_height: True
                spacing: dp(8)

                MDRaisedButton:
                    text: "Upload Audio"
                    md_bg_color: .49, .29, .68, 1
                    text_color: 1, 1, 1, 1
                    size_hint_x: None
                    width: dp(130)
                    on_release: root.pick_audio_file()

                MDLabel:
                    id: audio_path_label
                    text: "No audio selected"
                    theme_text_color: "Custom"
                    text_color: .78, .78, .86, 1
                    shorten: True

        MDLabel:
            id: add_msg
            text: ""
            halign: "center"
            theme_text_color: "Custom"
            text_color: 1, .45, .75, 1
            size_hint_y: None
            height: dp(24)

        MDRaisedButton:
            text: "Add Song"
            md_bg_color: .78, .32, .72, 1
            text_color: 1, 1, 1, 1
            size_hint_y: None
            height: dp(46)
            on_release: root.on_add_song()

        MDLabel:
            text: "Your Added Songs"
            font_style: "Subtitle1"
            theme_text_color: "Custom"
            text_color: .92, .92, .96, 1
            size_hint_y: None
            height: dp(28)

        ScrollView:
            bar_width: 0

            MDBoxLayout:
                id: add_song_list
                orientation: "vertical"
                adaptive_height: True
                spacing: dp(10)


<HomeScreen>:
    name: "home"
    md_bg_color: .10, .06, .17, 1

    MDBottomNavigation:
        panel_color: .08, .04, .13, 1
        text_color_active: 1, .63, .85, 1
        text_color_normal: .55, .55, .65, 1
        use_text: True

        MDBottomNavigationItem:
            name: "home_tab"
            text: "Home"
            icon: "home-variant"

            MDBoxLayout:
                orientation: "vertical"
                padding: [dp(18), dp(16), dp(18), dp(12)]
                spacing: dp(14)

                MDBoxLayout:
                    adaptive_height: True
                    spacing: dp(8)

                    MDIcon:
                        icon: "music-box-multiple"
                        theme_text_color: "Custom"
                        text_color: 1, .63, .85, 1

                    MDLabel:
                        text: "Now Trending"
                        font_style: "H6"
                        bold: True
                        theme_text_color: "Custom"
                        text_color: 1, 1, 1, 1

                    Widget:

                    MDIconButton:
                        icon: "heart-multiple"
                        theme_text_color: "Custom"
                        text_color: .87, .87, .95, 1
                        on_release: root.go_favorite()

                    MDIconButton:
                        icon: "account-circle-outline"
                        theme_text_color: "Custom"
                        text_color: .87, .87, .95, 1
                        on_release: root.go_profile()

                    MDIconButton:
                        icon: "playlist-plus"
                        theme_text_color: "Custom"
                        text_color: .87, .87, .95, 1
                        on_release: root.go_add_song()

                    MDIconButton:
                        icon: "logout"
                        theme_text_color: "Custom"
                        text_color: .87, .87, .95, 1
                        on_release: app.root.logout()

                MDCard:
                    size_hint_y: None
                    height: dp(44)
                    radius: [22,]
                    elevation: 0
                    md_bg_color: 1, 1, 1, .08
                    padding: [dp(14), 0, dp(8), 0]

                    MDBoxLayout:
                        spacing: dp(8)

                        MDIcon:
                            icon: "magnify"
                            pos_hint: {"center_y": .5}
                            theme_text_color: "Custom"
                            text_color: .75, .75, .82, 1

                        TextInput:
                            hint_text: "Search songs, artists, playlists"
                            background_color: 0, 0, 0, 0
                            foreground_color: 1, 1, 1, 1
                            hint_text_color: .65, .65, .75, 1
                            cursor_color: 1, 1, 1, 1
                            multiline: False
                            pos_hint: {"center_y": .5}

                ScrollView:
                    bar_width: 0

                    MDBoxLayout:
                        orientation: "vertical"
                        adaptive_height: True
                        spacing: dp(12)

                        MDCard:
                            size_hint_y: None
                            height: dp(130)
                            radius: [22,]
                            elevation: 0
                            md_bg_color: .18, .12, .30, 1
                            padding: dp(14)

                            MDBoxLayout:
                                orientation: "vertical"
                                spacing: dp(6)

                                MDLabel:
                                    text: "Fresh Picks"
                                    font_style: "H6"
                                    theme_text_color: "Custom"
                                    text_color: 1, 1, 1, 1
                                    bold: True

                                MDLabel:
                                    text: "Tap any track to open player"
                                    font_style: "Caption"
                                    theme_text_color: "Custom"
                                    text_color: .82, .82, .90, 1

                                Widget:

                                MDBoxLayout:
                                    adaptive_height: True
                                    spacing: dp(8)

                                    MDRoundFlatIconButton:
                                        text: "Chill"
                                        icon: "weather-night"
                                        size_hint: None, None
                                        size: dp(95), dp(34)
                                        text_color: 1, 1, 1, 1
                                        line_color: .85, .65, 1, 1

                                    MDRoundFlatIconButton:
                                        text: "Pop"
                                        icon: "music"
                                        size_hint: None, None
                                        size: dp(85), dp(34)
                                        text_color: 1, 1, 1, 1
                                        line_color: .85, .65, 1, 1

                                    MDRoundFlatIconButton:
                                        text: "Focus"
                                        icon: "brain"
                                        size_hint: None, None
                                        size: dp(95), dp(34)
                                        text_color: 1, 1, 1, 1
                                        line_color: .85, .65, 1, 1

