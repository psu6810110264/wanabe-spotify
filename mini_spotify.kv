<SongCard>:
    orientation: "horizontal"
    size_hint_y: None
    height: dp(70)
    padding: dp(10)
    spacing: dp(15)
    radius: [10,]
    ripple_behavior: True
    md_bg_color: 1, 1, 1, .05 
    elevation: 0

    MDCard:
        size_hint: None, None
        size: dp(50), dp(50)
        radius: [8,]
        md_bg_color: .2, .1, .3, 1
        pos_hint: {'center_y': .5}
        MDIcon:
            icon: root.image_icon
            halign: "center"
            pos_hint: {'center_y': .5}
            theme_text_color: "Custom"
            text_color: 1, 1, 1, 1

    MDBoxLayout:
        orientation: "vertical"
        alignment: "center_y"
        spacing: dp(2)
        MDLabel:
            text: root.title
            bold: True
            font_style: "Subtitle1"
            theme_text_color: "Custom"
            text_color: 1, 1, 1, 1
        MDLabel:
            text: root.artist
            font_style: "Caption"
            theme_text_color: "Custom"
            text_color: .8, .8, .8, 1

    MDBoxLayout:
        orientation: "vertical"
        alignment: "center_y"
        size_hint_x: None
        width: dp(40)
        MDLabel:
            text: root.rank
            halign: "right"
            font_style: "Caption"
            theme_text_color: "Custom"
            text_color: .8, .6, 1, 1
        MDLabel:
            text: root.duration
            halign: "right"
            font_style: "Caption"
            theme_text_color: "Custom"
            text_color: .8, .8, .8, 1

<RecommendCard>:
    orientation: "vertical"
    size_hint: None, None
    size: dp(110), dp(150)
    spacing: dp(5)
    md_bg_color: 0, 0, 0, 0 
    elevation: 0

    MDCard:
        size_hint: None, None
        size: dp(110), dp(110)
        radius: [15,]
        md_bg_color: .3, .2, .1, 1
        MDIcon:
            icon: root.image_icon
            halign: "center"
            font_size: dp(50)
            pos_hint: {'center_y': .5}
            theme_text_color: "Custom"
            text_color: 1, 1, 1, 1

    MDLabel:
        text: root.title
        font_style: "Subtitle2"
        theme_text_color: "Custom"
        text_color: 1, 1, 1, 1
        shorten: True
        shorten_from: 'right'
    MDLabel:
        text: root.subtitle
        font_style: "Caption"
        theme_text_color: "Custom"
        text_color: .7, .7, .7, 1
        shorten: True

<HomeScreen>:
    md_bg_color: .10, .06, .17, 1

    MDBottomNavigation:
        panel_color: .08, .04, .13, 1
        text_color_active: 1, .63, .85, 1
        text_color_normal: .55, .55, .65, 1
        use_text: True

        MDBottomNavigationItem:
            name: "home_tab"
            text: "Home"
            icon: "home-variant"

            MDBoxLayout:
                orientation: "vertical"
                padding: [dp(18), dp(16), dp(18), dp(12)]
                spacing: dp(14)

                MDBoxLayout:
                    adaptive_height: True
                    spacing: dp(8)
                    MDIcon:
                        icon: "music-box-multiple"
                        theme_text_color: "Custom"
                        text_color: 1, .63, .85, 1
                    MDLabel:
                        text: "Now Trending"
                        font_style: "H6"
                        bold: True
                        theme_text_color: "Custom"
                        text_color: 1, 1, 1, 1
                    MDIconButton:
                        icon: "account-circle-outline"
                        theme_text_color: "Custom"
                        text_color: .87, .87, .95, 1

                MDCard:
                    size_hint_y: None
                    height: dp(44)
                    radius: [22,]
                    elevation: 0
                    md_bg_color: 1, 1, 1, .08
                    padding: [dp(14), 0, dp(8), 0]

                    MDIcon:
                        icon: "magnify"
                        pos_hint: {"center_y": .5}
                        theme_text_color: "Custom"
                        text_color: .75, .75, .82, 1

                    TextInput:
                        hint_text: "Search songs, artists, playlists"
                        background_color: 0, 0, 0, 0
                        foreground_color: 1, 1, 1, 1
                        hint_text_color: .65, .65, .75, 1
                        cursor_color: 1, 1, 1, 1
                        multiline: False
                        pos_hint: {"center_y": .5}

                ScrollView:
                    bar_width: 0
                    MDBoxLayout:
                        orientation: "vertical"
                        adaptive_height: True
                        spacing: dp(12)

                        MDCard:
                            size_hint_y: None
                            height: dp(130)
                            radius: [22,]
                            elevation: 0
                            md_bg_color: .18, .12, .30, 1
                            padding: dp(14)

                            MDBoxLayout:
                                orientation: "vertical"
                                spacing: dp(6)

                                MDLabel:
                                    text: "Fresh Picks"
                                    font_style: "H6"
                                    theme_text_color: "Custom"
                                    text_color: 1, 1, 1, 1
                                    bold: True

                                MDLabel:
                                    text: "Tap any track to open player"
                                    font_style: "Caption"
                                    theme_text_color: "Custom"
                                    text_color: .82, .82, .90, 1

                                Widget:

                                MDBoxLayout:
                                    adaptive_height: True
                                    spacing: dp(8)

                                    MDChip:
                                        text: "Chill"
                                        icon: "weather-night"
                                    MDChip:
                                        text: "Pop"
                                        icon: "music"
                                    MDChip:
                                        text: "Focus"
                                        icon: "brain"

                        SongCard:
                            title: "Midnight Dreams"
                            artist: "The Dreamers"
                            rank: "#1"
                            duration: "3:45"
                            image_icon: "weather-night"
                            on_release: root.open_player(self.title, self.artist, self.duration)

                        SongCard:
                            title: "Summer Vibes"
                            artist: "Beach Boys Revival"
                            rank: "#2"
                            duration: "4:12"
                            image_icon: "beach"
                            on_release: root.open_player(self.title, self.artist, self.duration)

                        SongCard:
                            title: "Electric Soul"
                            artist: "Neon Lights"
                            rank: "#3"
                            duration: "3:28"
                            image_icon: "flash"
                            on_release: root.open_player(self.title, self.artist, self.duration)

                        SongCard:
                            title: "Ocean Radio"
                            artist: "Blue Echo"
                            rank: "#4"
                            duration: "2:56"
                            image_icon: "radio"
                            on_release: root.open_player(self.title, self.artist, self.duration)

                        MDCard:
                            size_hint_y: None
                            height: dp(60)
                            radius: [16,]
                            elevation: 0
                            md_bg_color: 1, 1, 1, .08
                            padding: [dp(14), 0, dp(10), 0]
                            on_release: root.open_player("Midnight Dreams", "The Dreamers", "3:45")

                            MDBoxLayout:
                                spacing: dp(8)
                                MDIcon:
                                    icon: "music-circle"
                                    theme_text_color: "Custom"
                                    text_color: 1, .63, .85, 1
                                    pos_hint: {"center_y": .5}
                                MDLabel:
                                    text: "Continue Playing"
                                    theme_text_color: "Custom"
                                    text_color: 1, 1, 1, 1
                                    pos_hint: {"center_y": .5}
                                MDIcon:
                                    icon: "play-circle"
                                    theme_text_color: "Custom"
                                    text_color: 1, 1, 1, 1
                                    pos_hint: {"center_y": .5}

        MDBottomNavigationItem:
            name: "search_tab"
            text: "Search"
            icon: "magnify"

            MDBoxLayout:
                orientation: "vertical"
                padding: [dp(18), dp(16), dp(18), dp(16)]
                spacing: dp(14)

                MDLabel:
                    text: "Search"
                    font_style: "H6"
                    bold: True
                    theme_text_color: "Custom"
                    text_color: 1, 1, 1, 1

                MDCard:
                    size_hint_y: None
                    height: dp(46)
                    radius: [23,]
                    elevation: 0
                    md_bg_color: 1, 1, 1, .10
                    padding: [dp(14), 0, dp(12), 0]

                    MDIcon:
                        icon: "magnify"
                        pos_hint: {"center_y": .5}
                        theme_text_color: "Custom"
                        text_color: .78, .78, .86, 1

                    TextInput:
                        hint_text: "What do you want to listen to?"
                        background_color: 0, 0, 0, 0
                        foreground_color: 1, 1, 1, 1
                        hint_text_color: .66, .66, .75, 1
                        multiline: False
                        cursor_color: 1, 1, 1, 1
                        pos_hint: {"center_y": .5}

                MDLabel:
                    text: "Browse Genres"
                    font_style: "Subtitle1"
                    theme_text_color: "Custom"
                    text_color: .92, .92, .96, 1

                MDGridLayout:
                    cols: 2
                    spacing: dp(10)
                    adaptive_height: True

                    MDCard:
                        size_hint_y: None
                        height: dp(94)
                        radius: [18,]
                        elevation: 0
                        md_bg_color: .37, .16, .20, 1
                        MDLabel:
                            text: "Pop"
                            bold: True
                            halign: "center"
                            theme_text_color: "Custom"
                            text_color: 1, 1, 1, 1

                    MDCard:
                        size_hint_y: None
                        height: dp(94)
                        radius: [18,]
                        elevation: 0
                        md_bg_color: .15, .31, .20, 1
                        MDLabel:
                            text: "Indie"
                            bold: True
                            halign: "center"
                            theme_text_color: "Custom"
                            text_color: 1, 1, 1, 1

                    MDCard:
                        size_hint_y: None
                        height: dp(94)
                        radius: [18,]
                        elevation: 0
                        md_bg_color: .17, .21, .40, 1
                        MDLabel:
                            text: "EDM"
                            bold: True
                            halign: "center"
                            theme_text_color: "Custom"
                            text_color: 1, 1, 1, 1

                    MDCard:
                        size_hint_y: None
                        height: dp(94)
                        radius: [18,]
                        elevation: 0
                        md_bg_color: .39, .28, .14, 1
                        MDLabel:
                            text: "Acoustic"
                            bold: True
                            halign: "center"
                            theme_text_color: "Custom"
                            text_color: 1, 1, 1, 1

        MDBottomNavigationItem:
            name: "my_music_tab"
            text: "My Music"
            icon: "book-open-variant"

            MDBoxLayout:
                orientation: "vertical"
                padding: [dp(18), dp(16), dp(18), dp(16)]
                spacing: dp(14)

                MDBoxLayout:
                    adaptive_height: True
                    MDLabel:
                        text: "My Music"
                        font_style: "H6"
                        bold: True
                        theme_text_color: "Custom"
                        text_color: 1, 1, 1, 1
                    MDIconButton:
                        icon: "cog-outline"
                        theme_text_color: "Custom"
                        text_color: .85, .85, .92, 1

                MDCard:
                    size_hint_y: None
                    height: dp(110)
                    radius: [24,]
                    elevation: 0
                    md_bg_color: .18, .16, .35, 1
                    padding: [dp(14), dp(12), dp(14), dp(12)]

                    MDBoxLayout:
                        spacing: dp(12)

                        MDCard:
                            size_hint: None, None
                            size: dp(54), dp(54)
                            radius: [27,]
                            elevation: 0
                            md_bg_color: .31, .22, .53, 1

                            MDIcon:
                                icon: "account"
                                halign: "center"
                                valign: "middle"
                                theme_text_color: "Custom"
                                text_color: 1, 1, 1, 1

                        MDBoxLayout:
                            orientation: "vertical"
                            spacing: dp(2)

                            MDLabel:
                                text: "Your Library"
                                font_style: "Subtitle1"
                                bold: True
                                theme_text_color: "Custom"
                                text_color: 1, 1, 1, 1

                            MDLabel:
                                text: "28 songs  |  6 playlists"
                                font_style: "Caption"
                                theme_text_color: "Custom"
                                text_color: .85, .85, .93, 1

                            MDBoxLayout:
                                adaptive_height: True
                                spacing: dp(8)

                                MDChip:
                                    text: "Downloaded"
                                    icon: "download"
                                MDChip:
                                    text: "Liked"
                                    icon: "heart"

                ScrollView:
                    bar_width: 0
                    MDBoxLayout:
                        orientation: "vertical"
                        adaptive_height: True
                        spacing: dp(10)

                        MDLabel:
                            text: "Quick Picks"
                            font_style: "Subtitle1"
                            theme_text_color: "Custom"
                            text_color: .90, .90, .97, 1

                        MDCard:
                            size_hint_y: None
                            height: dp(58)
                            radius: [16,]
                            elevation: 0
                            md_bg_color: .23, .14, .27, 1
                            padding: [dp(12), 0, dp(10), 0]
                            on_release: root.open_player("Pixel Heart", "Nova Kids", "2:48")

                            MDBoxLayout:
                                spacing: dp(8)
                                MDIcon:
                                    icon: "star-circle"
                                    pos_hint: {"center_y": .5}
                                    theme_text_color: "Custom"
                                    text_color: 1, .78, .35, 1
                                MDLabel:
                                    text: "Most Played This Week"
                                    theme_text_color: "Custom"
                                    text_color: 1, 1, 1, 1
                                    pos_hint: {"center_y": .5}
                                MDIcon:
                                    icon: "play"
                                    pos_hint: {"center_y": .5}
                                    theme_text_color: "Custom"
                                    text_color: .92, .92, 1, 1

                        MDLabel:
                            text: "Recently Played"
                            font_style: "Subtitle1"
                            theme_text_color: "Custom"
                            text_color: .90, .90, .97, 1

                        SongCard:
                            title: "Moonlight Avenue"
                            artist: "Sora"
                            rank: "01"
                            duration: "3:10"
                            image_icon: "music-note-outline"
                            on_release: root.open_player(self.title, self.artist, self.duration)

                        SongCard:
                            title: "Deep Blue"
                            artist: "Astra"
                            rank: "02"
                            duration: "4:05"
                            image_icon: "waves"
                            on_release: root.open_player(self.title, self.artist, self.duration)

                        SongCard:
                            title: "Pixel Heart"
                            artist: "Nova Kids"
                            rank: "03"
                            duration: "2:48"
                            image_icon: "heart"
                            on_release: root.open_player(self.title, self.artist, self.duration)

                        SongCard:
                            title: "Red Skyline"
                            artist: "Yuna"
                            rank: "04"
                            duration: "3:32"
                            image_icon: "city-variant-outline"
                            on_release: root.open_player(self.title, self.artist, self.duration)

<PlayerScreen>:
    md_bg_color: .07, .04, .14, 1

    MDBoxLayout:
        orientation: "vertical"
        padding: [dp(18), dp(18), dp(18), dp(18)]
        spacing: dp(16)

        MDBoxLayout:
            adaptive_height: True
            MDIconButton:
                icon: "arrow-left"
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1
                on_release: root.back_home()
            Widget:
            MDIconButton:
                icon: "dots-horizontal"
                theme_text_color: "Custom"
                text_color: .9, .9, .95, 1

        MDCard:
            size_hint_y: None
            height: dp(300)
            radius: [32,]
            elevation: 0
            md_bg_color: .20, .13, .34, 1
            padding: dp(24)

            MDBoxLayout:
                orientation: "vertical"
                spacing: dp(14)

                Widget:

                MDIcon:
                    icon: "album"
                    halign: "center"
                    font_size: "128sp"
                    theme_text_color: "Custom"
                    text_color: 1, .63, .85, 1

                MDLabel:
                    text: "MINI SPOTIFY"
                    halign: "center"
                    font_style: "Button"
                    theme_text_color: "Custom"
                    text_color: .86, .86, .95, 1

                Widget:

        MDBoxLayout:
            orientation: "vertical"
            size_hint_y: None
            height: dp(64)
            spacing: dp(6)

            MDLabel:
                text: root.song_title
                font_style: "H6"
                bold: True
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1
                size_hint_y: None
                height: self.texture_size[1]
                text_size: self.width, None
                valign: "middle"
                shorten: True

            MDLabel:
                text: root.song_artist
                font_style: "Subtitle2"
                theme_text_color: "Custom"
                text_color: .77, .77, .84, 1
                size_hint_y: None
                height: self.texture_size[1]
                text_size: self.width, None
                valign: "middle"
                shorten: True

        MDSlider:
            min: 0
            max: 100
            value: root.progress
            color: 1, .63, .85, 1
            hint: False
            on_value: root.on_seek(self.value)

        MDBoxLayout:
            adaptive_height: True
            MDLabel:
                text: root.current_time
                font_style: "Caption"
                theme_text_color: "Custom"
                text_color: .72, .72, .80, 1
            MDLabel:
                text: root.song_duration
                font_style: "Caption"
                halign: "right"
                theme_text_color: "Custom"
                text_color: .72, .72, .80, 1

        Widget:

        MDBoxLayout:
            adaptive_height: True
            spacing: dp(16)
            padding: [dp(6), 0, dp(6), 0]

            MDIconButton:
                icon: "skip-previous"
                user_font_size: "42sp"
                theme_text_color: "Custom"
                text_color: .93, .93, 1, 1
                on_release: root.on_prev()

            MDRoundFlatIconButton:
                text: "Pause" if root.is_playing else "Play"
                icon: "pause" if root.is_playing else "play"
                md_bg_color: 1, .63, .85, 1
                text_color: .12, .08, .18, 1
                line_color: 1, .63, .85, 1
                on_release: root.toggle_play_pause()

            MDIconButton:
                icon: "skip-next"
                user_font_size: "42sp"
                theme_text_color: "Custom"
                text_color: .93, .93, 1, 1
                on_release: root.on_next()

MDScreenManager:
    HomeScreen:
        name: "home"

    PlayerScreen:
        name: "player"